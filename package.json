{
  "name": "claw-pet",
  "version": "0.1.0",
  "description": "A cute desktop pet for OpenClaw — displays AI status, reacts to tool calls, and has personality",
  "type": "module",
  "main": "./electron/main.cjs",
  "scripts": {
    "build:renderer": "node esbuild.config.mjs",
    "build:extension": "tsc",
    "build": "npm run build:renderer",
    "dev": "npm run build:renderer && node esbuild.config.mjs --dev",
    "start": "npm run build && electron .",
    "start:dev": "npm run build:renderer --dev && electron .",
    "package": "npm run build && electron-builder --win portable",
    "package:all": "npm run build && electron-builder -wml",
    "check": "node tools/check-deps.mjs",
    "setup": "node tools/check-deps.mjs --fix"
  },
  "openclaw": {
    "id": "claw-pet",
    "extensions": ["./extension/index.js"]
  },
  "keywords": [
    "openclaw",
    "desktop-pet",
    "ai-companion",
    "electron",
    "openclaw-extension"
  ],
  "author": "",
  "license": "MIT",
  "homepage": "https://github.com/llghd/claw-pet",
  "repository": {
    "type": "git",
    "url": "https://github.com/llghd/claw-pet"
  },
  "dependencies": {
    "ws": "^8.0.0"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.0.0",
    "typescript": "^5.0.0",
    "esbuild": "^0.20.0"
  },
  "build": {
    "appId": "com.openclaw.claw-pet",
    "productName": "ClawPet",
    "win": {
      "target": ["nsis", "portable"],
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": ["dmg"],
      "icon": "assets/icon.icns"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "portable": {
      "artifactName": "${productName}-portable.exe"
    }
  }
}
