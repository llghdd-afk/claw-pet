{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "node",
    "outDir": "./extension",
    "rootDir": "./extension",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "sourceMap": true
  },
  "include": ["extension/**/*.ts"],
  "exclude": ["node_modules", "dist", "renderer"]
}
